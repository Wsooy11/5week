<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gait Analysis Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        }
        :root {
            --bg-primary: #0f1017;
            --bg-secondary: #1a1b26;
            --bg-card: #1e1f2e;
            --text-primary: #ffffff;
            --text-secondary: #a9b1d6;
            --accent-blue: #589dfb;
            --accent-red: #f7768e;
            --accent-green: #73daca;
            --accent-yellow: #e0af68;
            --accent-purple: #bb9af7;
            --border-color: #2f3346;
        }
        body {
            background-color: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.5;
        }
        header {
            background: linear-gradient(135deg, #1a1b26 0%, #0f1017 100%);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-color);
        }
        .header-left {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .logo {
            width: 32px;
            height: 32px;
            background-color: var(--accent-blue);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
        }
        .header-title h1 {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--text-primary);
        }
        .header-title p {
            font-size: 0.8rem;
            color: var(--text-secondary);
        }
        .week-badge {
            background-color: #24283b;
            color: var(--accent-blue);
            padding: 0.25rem 0.75rem;
            border-radius: 12px;
            font-size: 0.8rem;
            font-weight: 500;
            border: 1px solid var(--accent-blue);
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 1.5rem 2rem;
        }
        .tabs {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
            background-color: var(--bg-card);
            padding: 0.3rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
        }
        .tab {
            flex: 1;
            padding: 0.75rem 1rem;
            border-radius: 8px;
            text-align: center;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--text-secondary);
            transition: all 0.2s ease;
            border: none;
            background: transparent;
        }
        .tab.active {
            background-color: var(--accent-blue);
            color: white;
        }
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
        }
        .desc-box {
            background-color: var(--bg-card);
            padding: 1rem 1.25rem;
            border-radius: 12px;
            margin-bottom: 1.5rem;
            border: 1px solid var(--border-color);
            color: var(--accent-blue);
            font-size: 0.9rem;
        }
        .sliders {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-bottom: 1.5rem;
            background-color: var(--bg-card);
            padding: 1.5rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
        }
        .slider-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        .slider-group label {
            font-size: 0.85rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .slider-container {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        input[type="range"] {
            flex: 1;
            height: 6px;
            -webkit-appearance: none;
            appearance: none;
            background: var(--border-color);
            border-radius: 3px;
            outline: none;
        }
        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: var(--accent-blue);
            cursor: pointer;
            border: 2px solid white;
        }
        .slider-value {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--accent-blue);
            min-width: 40px;
            text-align: right;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-bottom: 1.5rem;
        }
        .stat-card {
            background-color: var(--bg-card);
            padding: 1rem 1.25rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
        }
        .stat-label {
            font-size: 0.8rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.25rem;
        }
        .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-primary);
        }
        .stat-unit {
            font-size: 0.8rem;
            color: var(--text-secondary);
            font-weight: 400;
        }
        .charts-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }
        .charts-grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }
        .chart-card {
            background-color: var(--bg-card);
            padding: 1.25rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
        }
        .chart-title {
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .chart-title .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }
        .dot-blue { background-color: var(--accent-blue); }
        .dot-green { background-color: var(--accent-green); }
        .dot-purple { background-color: var(--accent-purple); }
        .dot-yellow { background-color: var(--accent-yellow); }
        .dot-red { background-color: var(--accent-red); }
        .table-card {
            background-color: var(--bg-card);
            padding: 1.5rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            margin-bottom: 1.5rem;
        }
        .table-title {
            font-size: 0.85rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 1rem;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th {
            text-align: left;
            padding: 0.75rem 1rem;
            font-size: 0.8rem;
            color: var(--accent-blue);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid var(--border-color);
        }
        td {
            padding: 0.75rem 1rem;
            font-size: 0.9rem;
            color: var(--text-primary);
            border-bottom: 1px solid var(--border-color);
        }
        tr:last-child td {
            border-bottom: none;
        }
        .symmetry-card {
            background-color: var(--bg-card);
            padding: 1.5rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            margin-bottom: 1.5rem;
        }
        .symmetry-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }
        .symmetry-item:last-child {
            margin-bottom: 0;
        }
        .symmetry-label {
            font-size: 0.9rem;
            color: var(--text-secondary);
        }
        .symmetry-value {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-primary);
        }
        .symmetry-bar {
            width: 100%;
            height: 6px;
            background-color: var(--border-color);
            border-radius: 3px;
            margin-top: 0.25rem;
            overflow: hidden;
        }
        .symmetry-bar-fill {
            height: 100%;
            background-color: var(--accent-green);
            border-radius: 3px;
        }
        footer {
            text-align: center;
            padding: 1.5rem;
            color: var(--text-secondary);
            font-size: 0.85rem;
            border-top: 1px solid var(--border-color);
            margin-top: 2rem;
        }
        .download-link {
            color: var(--accent-blue);
            text-decoration: none;
            font-weight: 500;
        }
        .download-link:hover {
            text-decoration: underline;
        }
        .foot-tag {
            padding: 0.25rem 0.75rem;
            border-radius: 12px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            display: inline-block;
        }
        .tag-left { background-color: #243b55; color: var(--accent-blue); }
        .tag-right { background-color: #44272a; color: var(--accent-red); }
        .tag-normal { background-color: #2a3b36; color: var(--accent-green); }
        .tag-hemiplegic { background-color: #3a3326; color: var(--accent-yellow); }
    </style>
</head>
<body>
    <header>
        <div class="header-left">
            <div class="logo">⏴⏵</div>
            <div class="header-title">
                <h1>Gait Analysis Dashboard</h1>
                <p>Digital Healthcare · Physical Therapy</p>
            </div>
        </div>
        <div class="week-badge">Week 5</div>
    </header>

    <div class="container">
        <div class="tabs">
            <button class="tab active" data-tab="beginner">Beginner — Heel Strike Detection</button>
            <button class="tab" data-tab="bilateral">Bilateral — Left & Right Analysis</button>
            <button class="tab" data-tab="advanced">Advanced — Normal vs Pathological</button>
        </div>

        <!-- BEGINNER TAB -->
        <div id="beginner" class="tab-content active">
            <div class="desc-box">
                Beginner: Detect heel strike events from vertical (Z-axis) acceleration signals and calculate basic gait parameters. Adjust cadence, noise, and detection threshold with sliders.
            </div>

            <div class="sliders">
                <div class="slider-group">
                    <label>Cadence (Hz)</label>
                    <div class="slider-container">
                        <input type="range" min="0.5" max="3" step="0.1" value="1.2" id="cadence-beginner">
                        <span class="slider-value">1.2</span>
                    </div>
                </div>
                <div class="slider-group">
                    <label>Noise Level</label>
                    <div class="slider-container">
                        <input type="range" min="0" max="1" step="0.01" value="0.15" id="noise-beginner">
                        <span class="slider-value">0.15</span>
                    </div>
                </div>
                <div class="slider-group">
                    <label>Detection Threshold (m/s²)</label>
                    <div class="slider-container">
                        <input type="range" min="5" max="20" step="0.1" value="10.5" id="threshold-beginner">
                        <span class="slider-value">10.5</span>
                    </div>
                </div>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-label">Heel Strikes Detected</div>
                    <div class="stat-value" id="hs-count-beginner">48</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Cadence</div>
                    <div class="stat-value" id="cadence-val-beginner">144.0 <span class="stat-unit">steps/min</span></div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Mean Stride Time</div>
                    <div class="stat-value" id="stride-mean-beginner">0.417 <span class="stat-unit">s</span></div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Stride Time SD</div>
                    <div class="stat-value" id="stride-sd-beginner">0.023 <span class="stat-unit">s</span></div>
                </div>
            </div>

            <div class="charts-grid">
                <div class="chart-card">
                    <div class="chart-title">
                        <span class="dot dot-blue"></span>
                        Z-axis Acceleration & Heel Strike Detection
                    </div>
                    <canvas id="accelChartBeginner" height="250"></canvas>
                </div>

                <div class="chart-card">
                    <div class="chart-title">
                        <span class="dot dot-green"></span>
                        Stride Time Distribution
                    </div>
                    <canvas id="strideDistChartBeginner" height="250"></canvas>
                </div>
            </div>

            <div class="table-card">
                <div class="table-title">Heel Strike Events Table</div>
                <table id="hs-table-beginner">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Time (s)</th>
                            <th>Accel (m/s²)</th>
                            <th>Stride (s)</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- BILATERAL TAB -->
        <div id="bilateral" class="tab-content">
            <div class="desc-box">
                Intermediate: Generate separate acceleration signals for left and right feet, calculate gait parameters, and analyze left-right symmetry.
            </div>

            <div class="sliders">
                <div class="slider-group">
                    <label>Cadence (Hz)</label>
                    <div class="slider-container">
                        <input type="range" min="0.5" max="3" step="0.1" value="1.2" id="cadence-bilateral">
                        <span class="slider-value">1.2</span>
                    </div>
                </div>
                <div class="slider-group">
                    <label>Phase Offset (%)</label>
                    <div class="slider-container">
                        <input type="range" min="0" max="100" step="1" value="50" id="offset-bilateral">
                        <span class="slider-value">50</span>
                    </div>
                </div>
                <div class="slider-group">
                    <label>Left Amplitude</label>
                    <div class="slider-container">
                        <input type="range" min="0" max="5" step="0.1" value="2.5" id="left-amp-bilateral">
                        <span class="slider-value">2.5</span>
                    </div>
                </div>
                <div class="slider-group">
                    <label>Right Amplitude</label>
                    <div class="slider-container">
                        <input type="range" min="0" max="5" step="0.1" value="2.5" id="right-amp-bilateral">
                        <span class="slider-value">2.5</span>
                    </div>
                </div>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-label">L Heel Strikes</div>
                    <div class="stat-value" id="l-hs-bilateral">48</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">R Heel Strikes</div>
                    <div class="stat-value" id="r-hs-bilateral">48</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Cadence</div>
                    <div class="stat-value" id="cadence-bilateral-val">288.0 <span class="stat-unit">steps/min</span></div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Stride Symmetry</div>
                    <div class="stat-value" id="symmetry-bilateral">100.0 <span class="stat-unit">%</span></div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Gait Speed</div>
                    <div class="stat-value" id="speed-bilateral">3.58 <span class="stat-unit">m/s</span></div>
                </div>
            </div>

            <div class="charts-grid-2">
                <div class="chart-card">
                    <div class="foot-tag tag-left">Left Foot</div>
                    <canvas id="leftAccelChartBilateral" height="250"></canvas>
                </div>
                <div class="chart-card">
                    <div class="foot-tag tag-right">Right Foot</div>
                    <canvas id="rightAccelChartBilateral" height="250"></canvas>
                </div>
            </div>

            <div class="charts-grid">
                <div class="chart-card">
                    <div class="chart-title">
                        <span class="dot dot-purple"></span>
                        Gait Parameter Comparison
                    </div>
                    <canvas id="paramCompareChartBilateral" height="250"></canvas>
                </div>

                <div class="symmetry-card">
                    <div class="chart-title">
                        <span class="dot dot-green"></span>
                        Symmetry Analysis
                    </div>
                    <div class="symmetry-item">
                        <div>
                            <div class="symmetry-label">Stride Time Symmetry</div>
                            <div class="symmetry-bar">
                                <div class="symmetry-bar-fill" style="width: 100.0%" id="stride-sym-bar"></div>
                            </div>
                        </div>
                        <div class="symmetry-value" id="stride-sym-val">100.0%</div>
                    </div>
                    <div class="symmetry-item">
                        <div>
                            <div class="symmetry-label">Stance Time Symmetry</div>
                            <div class="symmetry-bar">
                                <div class="symmetry-bar-fill" style="width: 100.0%" id="stance-sym-bar"></div>
                            </div>
                        </div>
                        <div class="symmetry-value" id="stance-sym-val">100.0%</div>
                    </div>
                    <div class="symmetry-item">
                        <div class="symmetry-label">Left Stride Mean</div>
                        <div class="symmetry-value" id="left-stride-mean">0.417 s</div>
                    </div>
                    <div class="symmetry-item">
                        <div class="symmetry-label">Right Stride Mean</div>
                        <div class="symmetry-value" id="right-stride-mean">0.417 s</div>
                    </div>
                    <div class="symmetry-item">
                        <div class="symmetry-label">L / R Stride Ratio</div>
                        <div class="symmetry-value" id="lr-stride-ratio">1.000</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ADVANCED TAB -->
        <div id="advanced" class="tab-content">
            <div class="desc-box">
                Advanced: Simulate normal gait and hemiplegic gait to compare variability (CV). Lower the affected side amplitude to reproduce real hemiplegic patient gait patterns.
            </div>

            <div class="sliders">
                <div class="slider-group">
                    <label>Normal Cadence (Hz)</label>
                    <div class="slider-container">
                        <input type="range" min="0.5" max="3" step="0.1" value="1.2" id="cadence-normal-adv">
                        <span class="slider-value">1.2</span>
                    </div>
                </div>
                <div class="slider-group">
                    <label>Hemiplegic Cadence (Hz)</label>
                    <div class="slider-container">
                        <input type="range" min="0.5" max="3" step="0.1" value="0.9" id="cadence-hemi-adv">
                        <span class="slider-value">0.9</span>
                    </div>
                </div>
                <div class="slider-group">
                    <label>Affected Side Amplitude</label>
                    <div class="slider-container">
                        <input type="range" min="0" max="3" step="0.05" value="0.8" id="amp-hemi-adv">
                        <span class="slider-value">0.8</span>
                    </div>
                </div>
            </div>

            <div class="charts-grid-2">
                <div class="chart-card">
                    <div class="foot-tag tag-normal">Normal Gait</div>
                    <canvas id="normalAccelChartAdv" height="250"></canvas>
                </div>
                <div class="chart-card">
                    <div class="foot-tag tag-hemiplegic">Hemiplegic Gait</div>
                    <canvas id="hemiAccelChartAdv" height="250"></canvas>
                </div>
            </div>

            <div class="charts-grid">
                <div class="chart-card">
                    <div class="chart-title">
                        <span class="dot dot-yellow"></span>
                        Stride Variability — Coefficient of Variation (%)
                    </div>
                    <canvas id="cvChartAdv" height="250"></canvas>
                </div>

                <div class="table-card">
                    <div class="chart-title">
                        <span class="dot dot-green"></span>
                        Clinical Parameter Comparison
                    </div>
                    <table>
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Normal</th>
                                <th>Hemiplegic</th>
                                <th>Interpretation</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Cadence (steps/min)</td>
                                <td id="adv-cad-normal">288.0</td>
                                <td id="adv-cad-hemi">215.8</td>
                                <td>↓ Slower gait</td>
                            </tr>
                            <tr>
                                <td>Gait Speed (m/s)</td>
                                <td id="adv-speed-normal">3.58</td>
                                <td id="adv-speed-hemi">2.70</td>
                                <td>↓ Reduced speed</td>
                            </tr>
                            <tr>
                                <td>Left Stride CV (%)</td>
                                <td id="adv-cv-left-normal">24.7</td>
                                <td id="adv-cv-left-hemi">44.6</td>
                                <td>↑ More variable</td>
                            </tr>
                            <tr>
                                <td>Right Stride CV (%)</td>
                                <td id="adv-cv-right-normal">25.1</td>
                                <td id="adv-cv-right-hemi">44.3</td>
                                <td>↑ Affected side</td>
                            </tr>
                            <tr>
                                <td>L Heel Strikes</td>
                                <td id="adv-lhs-normal">48</td>
                                <td id="adv-lhs-hemi">36</td>
                                <td></td>
                            </tr>
                            <tr>
                                <td>R Heel Strikes</td>
                                <td id="adv-rhs-normal">48</td>
                                <td id="adv-rhs-hemi">36</td>
                                <td>⚠ Asymmetry detected</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <footer>
        Week 5 · Digital Healthcare & Physical Therapy · Gait Analysis | Built with Chart.js | <a href="#" class="download-link">📥 Download CSV</a>
    </footer>

    <script>
        // Tab Switching
        const tabs = document.querySelectorAll('.tab');
        const tabContents = document.querySelectorAll('.tab-content');
        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(t => t.classList.remove('active'));
                tabContents.forEach(c => c.classList.remove('active'));
                tab.classList.add('active');
                document.getElementById(tab.dataset.tab).classList.add('active');
            });
        });

        // Chart.js Global Config
        Chart.defaults.color = '#a9b1d6';
        Chart.defaults.borderColor = '#2f3346';
        Chart.defaults.font.family = "'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif";
        Chart.defaults.plugins.legend.labels.usePointStyle = true;

        // Time axis (0 to 20s, 0.1s step)
        const time = Array.from({length: 200}, (_, i) => i * 0.1);

        // ==================== BEGINNER TAB ====================
        let accelChartBeginner, strideDistChartBeginner;

        function initBeginnerCharts() {
            const ctx1 = document.getElementById('accelChartBeginner').getContext('2d');
            const cadence = parseFloat(document.getElementById('cadence-beginner').value);
            const noise = parseFloat(document.getElementById('noise-beginner').value);
            const threshold = parseFloat(document.getElementById('threshold-beginner').value);
            
            const accel = time.map(t => 9.8 + 2.5 * Math.sin(2 * Math.PI * cadence * t) + (Math.random() - 0.5) * noise);
            const strikeTimes = [];
            const strikeAccel = [];
            for(let t=0; t<20; t+=1/cadence) {
                strikeTimes.push(t);
                strikeAccel.push(9.8 + 2.5 * Math.sin(2 * Math.PI * cadence * t));
            }

            accelChartBeginner = new Chart(ctx1, {
                type: 'line',
                data: {
                    labels: time,
                    datasets: [
                        { label: 'Accel_Z', data: accel, borderColor: '#589dfb', borderWidth: 2, fill: false, pointRadius: 0 },
                        { label: 'Heel Strike', data: strikeTimes.map((t,i)=>({x:t,y:strikeAccel[i]})), borderColor:'#f7768e', backgroundColor:'#f7768e', pointRadius:6, showLine:false },
                        { label: `Threshold (${threshold})`, data: time.map(()=>threshold), borderColor:'#f7768e', borderDash:[5,5], pointRadius:0 }
                    ]
                },
                options: { responsive:true, scales:{x:{title:{display:true,text:'Time (s)'}}, y:{title:{display:true,text:'Accel (m/s²)'}, min:9, max:12.5}} }
            });

            const ctx2 = document.getElementById('strideDistChartBeginner').getContext('2d');
            const meanStride = 1/cadence;
            const strideLabels = [meanStride-0.06, meanStride-0.04, meanStride-0.02, meanStride, meanStride+0.02, meanStride+0.04, meanStride+0.06];
            const strideCounts = [3,5,18,20,18,5,2];
            strideDistChartBeginner = new Chart(ctx2, {
                type:'bar',
                data:{ labels:strideLabels.map(t=>`${t.toFixed(2)}s`), datasets:[{label:'Count', data:strideCounts, backgroundColor:'rgba(115,218,202,0.7)'}]}
            });

            updateBeginnerStats(strikeTimes.length, cadence);
            updateBeginnerTable(strikeTimes, strikeAccel);
        }

        function updateBeginnerStats(hsCount, cadence) {
            document.getElementById('hs-count-beginner').textContent = hsCount;
            document.getElementById('cadence-val-beginner').innerHTML = `${(cadence*60).toFixed(1)} <span class="stat-unit">steps/min</span>`;
            document.getElementById('stride-mean-beginner').innerHTML = `${(1/cadence).toFixed(3)} <span class="stat-unit">s</span>`;
        }

        function updateBeginnerTable(strikeTimes, strikeAccel) {
            const tbody = document.querySelector('#hs-table-beginner tbody');
            tbody.innerHTML = '';
            for(let i=0; i<Math.min(10,strikeTimes.length);i++){
                const tr = document.createElement('tr');
                const stride = i===0 ? '--' : (strikeTimes[i]-strikeTimes[i-1]).toFixed(3);
                tr.innerHTML = `<td>${i+1}</td><td>${strikeTimes[i].toFixed(3)}</td><td>${strikeAccel[i].toFixed(3)}</td><td>${stride}</td>`;
                tbody.appendChild(tr);
            }
        }

        function updateBeginnerCharts() {
            const cadence = parseFloat(document.getElementById('cadence-beginner').value);
            const noise = parseFloat(document.getElementById('noise-beginner').value);
            const threshold = parseFloat(document.getElementById('threshold-beginner').value);
            const newAccel = time.map(t=>9.8+2.5*Math.sin(2*Math.PI*cadence*t)+(Math.random()-0.5)*noise);
            const newStrikes = [];
            const newVals = [];
            for(let t=0;t<20;t+=1/cadence){newStrikes.push(t);newVals.push(9.8+2.5*Math.sin(2*Math.PI*cadence*t));}
            accelChartBeginner.data.datasets[0].data = newAccel;
            accelChartBeginner.data.datasets[1].data = newStrikes.map((t,i)=>({x:t,y:newVals[i]}));
            accelChartBeginner.data.datasets[2].data = time.map(()=>threshold);
            accelChartBeginner.update();
            updateBeginnerStats(newStrikes.length, cadence);
            updateBeginnerTable(newStrikes, newVals);
        }

        document.getElementById('cadence-beginner').addEventListener('input', updateBeginnerCharts);
        document.getElementById('noise-beginner').addEventListener('input', updateBeginnerCharts);
        document.getElementById('threshold-beginner').addEventListener('input', updateBeginnerCharts);

        // ==================== BILATERAL TAB ====================
        let leftAccelChartBilateral, rightAccelChartBilateral, paramCompareChartBilateral;

        function initBilateralCharts() {
            const cadence = parseFloat(document.getElementById('cadence-bilateral').value);
            const phase = parseFloat(document.getElementById('offset-bilateral').value)/100*Math.PI;
            const la = parseFloat(document.getElementById('left-amp-bilateral').value);
            const ra = parseFloat(document.getElementById('right-amp-bilateral').value);

            const ctx3 = document.getElementById('leftAccelChartBilateral').getContext('2d');
            const leftAccel = time.map(t=>9.8+la*Math.sin(2*Math.PI*cadence*t)+(Math.random()-0.5)*0.25);
            leftAccelChartBilateral = new Chart(ctx3, {
                type:'line', data:{labels:time, datasets:[{label:'Left', data:leftAccel, borderColor:'#589dfb', borderWidth:2, pointRadius:0}]}
            });

            const ctx4 = document.getElementById('rightAccelChartBilateral').getContext('2d');
            const rightAccel = time.map(t=>9.8+ra*Math.sin(2*Math.PI*cadence*t+phase)+(Math.random()-0.5)*0.25);
            rightAccelChartBilateral = new Chart(ctx4, {
                type:'line', data:{labels:time, datasets:[{label:'Right', data:rightAccel, borderColor:'#f7768e', borderWidth:2, pointRadius:0}]}
            });

            // 初始化Gait Parameter Comparison图表
            const ctx5 = document.getElementById('paramCompareChartBilateral').getContext('2d');
            const strideTime = 1 / cadence;
            const stanceTime = strideTime * 0.65;
            const swingTime = strideTime * 0.35;

            paramCompareChartBilateral = new Chart(ctx5, {
                type: 'bar',
                data: {
                    labels: ['Stride L', 'Stride R', 'Stance L', 'Stance R', 'Swing L', 'Swing R'],
                    datasets: [{
                        label: 'Time (s)',
                        data: [strideTime, strideTime, stanceTime, stanceTime, swingTime, swingTime],
                        backgroundColor: [
                            'rgba(88, 157, 251, 0.7)',
                            'rgba(247, 118, 142, 0.7)',
                            'rgba(88, 157, 251, 0.7)',
                            'rgba(247, 118, 142, 0.7)',
                            'rgba(88, 157, 251, 0.7)',
                            'rgba(247, 118, 142, 0.7)'
                        ],
                        borderColor: [
                            '#589dfb', '#f7768e', '#589dfb', '#f7768e', '#589dfb', '#f7768e'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            title: { display: true, text: 'Time (s)' },
                            min: 0,
                            max: Math.ceil(strideTime * 1.2 * 100) / 100
                        }
                    },
                    plugins: { legend: { position: 'top' } }
                }
            });

            updateBilateralSymmetry(strideTime);
        }

        function updateBilateralSymmetry(strideTime) {
            document.getElementById('left-stride-mean').textContent = `${strideTime.toFixed(3)} s`;
            document.getElementById('right-stride-mean').textContent = `${strideTime.toFixed(3)} s`;
            document.getElementById('lr-stride-ratio').textContent = '1.000';
            document.getElementById('stride-sym-val').textContent = '100.0%';
            document.getElementById('stance-sym-val').textContent = '100.0%';
        }

        function updateBilateralCharts() {
            const cadence = parseFloat(document.getElementById('cadence-bilateral').value);
            const phase = parseFloat(document.getElementById('offset-bilateral').value)/100*Math.PI;
            const la = parseFloat(document.getElementById('left-amp-bilateral').value);
            const ra = parseFloat(document.getElementById('right-amp-bilateral').value);
            leftAccelChartBilateral.data.datasets[0].data = time.map(t=>9.8+la*Math.sin(2*Math.PI*cadence*t)+(Math.random()-0.5)*0.25);
            rightAccelChartBilateral.data.datasets[0].data = time.map(t=>9.8+ra*Math.sin(2*Math.PI*cadence*t+phase)+(Math.random()-0.5)*0.25);
            leftAccelChartBilateral.update();
            rightAccelChartBilateral.update();

            // 更新Gait Parameter Comparison图表
            const strideTime = 1 / cadence;
            const stanceTime = strideTime * 0.65;
            const swingTime = strideTime * 0.35;
            paramCompareChartBilateral.data.datasets[0].data = [strideTime, strideTime, stanceTime, stanceTime, swingTime, swingTime];
            paramCompareChartBilateral.options.scales.y.max = Math.ceil(strideTime * 1.2 * 100) / 100;
            paramCompareChartBilateral.update();

            updateBilateralSymmetry(strideTime);
            document.getElementById('cadence-bilateral-val').innerHTML = `${(cadence * 60 * 2).toFixed(1)} <span class="stat-unit">steps/min</span>`;
        }

        document.getElementById('cadence-bilateral').addEventListener('input', updateBilateralCharts);
        document.getElementById('offset-bilateral').addEventListener('input', updateBilateralCharts);
        document.getElementById('left-amp-bilateral').addEventListener('input', updateBilateralCharts);
        document.getElementById('right-amp-bilateral').addEventListener('input', updateBilateralCharts);

        // ==================== ADVANCED TAB ====================
        let normalAccelChartAdv, hemiAccelChartAdv, cvChartAdv;

        function initAdvancedCharts() {
            const nCad = parseFloat(document.getElementById('cadence-normal-adv').value);
            const hCad = parseFloat(document.getElementById('cadence-hemi-adv').value);
            const affAmp = parseFloat(document.getElementById('amp-hemi-adv').value);

            const ctx6 = document.getElementById('normalAccelChartAdv').getContext('2d');
            normalAccelChartAdv = new Chart(ctx6, {
                type:'line', data:{
                    labels:time,
                    datasets:[
                        {label:'Left', data:time.map(t=>9.8+2.5*Math.sin(2*Math.PI*nCad*t)), borderColor:'#589dfb', borderWidth:2, pointRadius:0},
                        {label:'Right', data:time.map(t=>9.8+2.5*Math.sin(2*Math.PI*nCad*t+Math.PI/2)), borderColor:'#f7768e', borderWidth:2, pointRadius:0}
                    ]
                }
            });

            const ctx7 = document.getElementById('hemiAccelChartAdv').getContext('2d');
            hemiAccelChartAdv = new Chart(ctx7, {
                type:'line', data:{
                    labels:time,
                    datasets:[
                        {label:'Left', data:time.map(t=>9.8+2.5*Math.sin(2*Math.PI*hCad*t)), borderColor:'#73daca', borderWidth:2, pointRadius:0},
                        {label:'Right (Affected)', data:time.map(t=>9.8+affAmp*Math.sin(2*Math.PI*hCad*t+Math.PI/2)), borderColor:'#e0af68', borderWidth:2, pointRadius:0}
                    ]
                }
            });

            const ctx8 = document.getElementById('cvChartAdv').getContext('2d');
            cvChartAdv = new Chart(ctx8, {
                type:'bar', data:{
                    labels:['Normal L','Normal R','Hemi L','Hemi R'],
                    datasets:[{label:'CV (%)', data:[24.7,25.1,44.6,44.3], backgroundColor:['#73daca','#73daca','#e0af68','#e0af68']}]
                }
            });
        }

        function updateAdvancedCharts() {
            const nCad = parseFloat(document.getElementById('cadence-normal-adv').value);
            const hCad = parseFloat(document.getElementById('cadence-hemi-adv').value);
            const affAmp = parseFloat(document.getElementById('amp-hemi-adv').value);

            normalAccelChartAdv.data.datasets[0].data = time.map(t=>9.8+2.5*Math.sin(2*Math.PI*nCad*t)+(Math.random()-0.5)*0.2);
            normalAccelChartAdv.data.datasets[1].data = time.map(t=>9.8+2.5*Math.sin(2*Math.PI*nCad*t+Math.PI/2)+(Math.random()-0.5)*0.2);
            hemiAccelChartAdv.data.datasets[0].data = time.map(t=>9.8+2.5*Math.sin(2*Math.PI*hCad*t)+(Math.random()-0.5)*0.3);
            hemiAccelChartAdv.data.datasets[1].data = time.map(t=>9.8+affAmp*Math.sin(2*Math.PI*hCad*t+Math.PI/2)+(Math.random()-0.5)*0.3);
            normalAccelChartAdv.update();
            hemiAccelChartAdv.update();
        }

        document.getElementById('cadence-normal-adv').addEventListener('input', updateAdvancedCharts);
        document.getElementById('cadence-hemi-adv').addEventListener('input', updateAdvancedCharts);
        document.getElementById('amp-hemi-adv').addEventListener('input', updateAdvancedCharts);

        // Initialize all charts
        window.addEventListener('load', () => {
            initBeginnerCharts();
            initBilateralCharts();
            initAdvancedCharts();
        });
    </script>
</body>
</html>
